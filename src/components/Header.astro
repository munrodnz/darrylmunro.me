---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE, NAV_LINKS } from "@/consts";

const { pathname } = Astro.url;
const currentPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  const currentPathArray = currentPath.split("/").filter((p) => p.trim());
  const pathArray = path.split("/").filter((p) => p.trim());
  return currentPathArray[0] === pathArray[0];
};
---

<nav class="sticky top-0 z-100 border-b border-border" style="background: rgba(var(--nav-bg-rgb, '25, 25, 24'), 0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
  <div class="mx-auto flex max-w-[740px] items-center justify-between px-6 h-14">
    <a href="/" class="font-[var(--font-head)] font-semibold text-[15px] text-foreground tracking-[0.01em] hover:no-underline">
      {SITE.author} <span class="text-accent">·</span> NZ
    </a>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="sm:hidden p-2 text-text-secondary hover:text-foreground transition-colors"
      aria-label="Open Menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <svg id="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Desktop nav -->
    <ul id="nav-links" class="hidden sm:flex items-center gap-7 list-none">
      {NAV_LINKS.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "font-[var(--font-body)] text-sm text-text-secondary tracking-[0.02em] transition-colors hover:text-foreground hover:no-underline",
              { "active-nav": isActive(href) },
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      {
        SITE.lightAndDarkMode && (
          <li>
            <button
              id="theme-btn"
              class="relative size-8 p-1 text-text-secondary hover:text-accent transition-colors"
              title="Toggle light & dark mode"
              aria-label="auto"
              aria-live="polite"
            >
              <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" width="16" height="16" />
              <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" width="16" height="16" />
            </button>
          </li>
        )
      }
    </ul>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-border">
    <ul class="flex flex-col py-4 px-6 gap-1 list-none">
      {NAV_LINKS.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "block py-2 text-sm text-text-secondary hover:text-foreground hover:no-underline transition-colors",
              { "active-nav !text-foreground": isActive(href) },
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      {
        SITE.lightAndDarkMode && (
          <li class="pt-2 border-t border-border mt-2">
            <button
              id="theme-btn-mobile"
              class="flex items-center gap-2 py-2 text-sm text-text-secondary hover:text-accent transition-colors"
              title="Toggle light & dark mode"
              aria-label="auto"
              aria-live="polite"
            >
              <IconMoon class="dark:hidden" width="16" height="16" />
              <IconSunHigh class="hidden dark:block" width="16" height="16" />
              <span class="dark:hidden">Dark mode</span>
              <span class="hidden dark:block">Light mode</span>
            </button>
          </li>
        )
      }
    </ul>
  </div>
</nav>

<script>
  function setupNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      menuBtn.setAttribute("aria-label", isOpen ? "Open Menu" : "Close Menu");
      mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });

    // Mobile theme toggle
    const themeBtnMobile = document.querySelector("#theme-btn-mobile");
    if (themeBtnMobile) {
      themeBtnMobile.addEventListener("click", () => {
        // Trigger the main theme button click
        const mainBtn = document.querySelector("#theme-btn") as HTMLButtonElement;
        if (mainBtn) mainBtn.click();
      });
    }
  }

  setupNav();
  document.addEventListener("astro:after-swap", setupNav);
</script>
