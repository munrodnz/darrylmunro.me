---
export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class:list={["w-full border-t border-border relative z-1", { "mt-auto": !noMarginTop }]}>
  <div class="mx-auto max-w-[740px] px-6 py-8 flex flex-col sm:flex-row justify-between items-center gap-4">
    <span class="text-[13px] text-muted font-[var(--font-mono)]">
      &copy; {new Date().getFullYear()} Darryl Munro &middot; <span class="text-accent">Otepoti</span>
    </span>
    <div class="flex gap-5">
      <a href="https://github.com/munrodnz" class="text-[13px] text-muted hover:text-foreground transition-colors hover:no-underline">GitHub</a>
      <a href="https://linkedin.com/in/darryl-munro" class="text-[13px] text-muted hover:text-foreground transition-colors hover:no-underline">LinkedIn</a>
      <a href="https://x.com/munrod10" class="text-[13px] text-muted hover:text-foreground transition-colors hover:no-underline">X</a>
      <a href="mailto:darryl@darrylmunro.nz" class="text-[13px] text-muted hover:text-foreground transition-colors hover:no-underline">Email</a>
    </div>
  </div>
</footer>
