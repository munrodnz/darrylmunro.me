---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`} description={frontmatter.description}>
  <Header />
  <main id="main-content" class="relative z-1">
    <div class="mx-auto max-w-[740px] px-6">
      <section class="pt-22 pb-10 relative" style="border: none;">
        <div class="absolute left-0 top-20 bottom-4 w-[3px] rounded-sm opacity-60" style="background: linear-gradient(180deg, var(--accent) 0%, var(--gold) 100%);"></div>

        <div class="font-[var(--font-mono)] text-xs font-medium text-accent tracking-[0.12em] uppercase mb-5 flex items-center gap-2.5">
          About
          <span class="block w-8 h-px bg-accent-dim"></span>
        </div>
        <h1 class="font-[var(--font-head)] text-[clamp(32px,5vw,44px)] font-bold leading-[1.1] tracking-[-0.02em] text-foreground mb-8">
          {frontmatter.title}
        </h1>
      </section>
      <section class="prose max-w-[740px] prose-img:border-0 pb-16" style="border: none;">
        <slot />
      </section>
    </div>
  </main>
  <Footer />
</Layout>
