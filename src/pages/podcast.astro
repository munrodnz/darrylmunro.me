---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";

// ── PODCAST CONFIG ────────────────────────────────────────────
// Update these constants to manage podcast details.
const PODCAST = {
  title: "Strong Opinions, Loosely Held",
  description: "Conversations with leaders, builders, and thinkers who aren't afraid to challenge the status quo. Enterprise architecture, AI, neurodiversity, leadership — and everything in between.",
  youtubeChannelId: "UCMa5y-p395989vIHfK4G--A",
  youtubeChannelUrl: "https://www.youtube.com/@techandlifetipswithdaz",
  spotifyShowId: "1VxomxEhsUcaaP1mzuTXId",
  spotifyUrl: "https://open.spotify.com/show/1VxomxEhsUcaaP1mzuTXId",
};

// ── FETCH EPISODES FROM YOUTUBE RSS ───────────────────────────
interface Episode {
  id: string;
  title: string;
  published: string;
  thumbnail: string;
}

let episodes: Episode[] = [];

// Fetch videos from YouTube channel page (more reliable than RSS feed)
async function fetchYouTubeVideos(channelUrl: string): Promise<Episode[]> {
  try {
    const response = await fetch(`${channelUrl}/videos`, {
      headers: { "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:120.0) Gecko/20100101 Firefox/120.0" },
    });
    if (!response.ok) return [];

    const html = await response.text();

    // Extract ytInitialData JSON
    const match = html.match(/var ytInitialData = ({.*?});<\/script>/);
    if (!match) return [];

    const data = JSON.parse(match[1]);
    const tabs = data?.contents?.twoColumnBrowseResultsRenderer?.tabs || [];

    for (const tab of tabs) {
      const tr = tab?.tabRenderer;
      if (!tr?.selected) continue;
      const items = tr?.content?.richGridRenderer?.contents || [];
      return items
        .filter((item: any) => item?.richItemRenderer?.content?.videoRenderer)
        .map((item: any) => {
          const video = item.richItemRenderer.content.videoRenderer;
          return {
            id: video.videoId,
            title: video.title?.runs?.[0]?.text || "",
            published: video.publishedTimeText?.simpleText || "",
            thumbnail: `https://i.ytimg.com/vi/${video.videoId}/hqdefault.jpg`,
          };
        });
    }
  } catch (error) {
    console.warn("Error fetching YouTube videos:", error);
  }
  return [];
}

// Try RSS feed first (has exact dates), fall back to page scrape
try {
  const feedUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${PODCAST.youtubeChannelId}`;
  const response = await fetch(feedUrl);
  if (response.ok) {
    const xml = await response.text();
    if (xml.includes("<entry>")) {
      const entries = xml.split("<entry>").slice(1);
      episodes = entries
        .map((entry) => {
          const vidMatch = entry.match(/<yt:videoId>([^<]+)/);
          const titleMatch = entry.match(/<title>([^<]+)/);
          const pubMatch = entry.match(/<published>([^<]+)/);
          if (!vidMatch || !titleMatch) return null;
          return {
            id: vidMatch[1],
            title: titleMatch[1].replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&#39;/g, "'").replace(/&quot;/g, '"'),
            published: pubMatch ? pubMatch[1].slice(0, 10) : "",
            thumbnail: `https://i.ytimg.com/vi/${vidMatch[1]}/hqdefault.jpg`,
          };
        })
        .filter((e): e is Episode => e !== null);
    }
  }
} catch {
  // RSS failed, will try page scrape
}

// Fall back to page scrape if RSS returned no results
if (episodes.length === 0) {
  episodes = await fetchYouTubeVideos(PODCAST.youtubeChannelUrl);
}

const featuredEpisode = episodes[0];
const remainingEpisodes = episodes.slice(1);

const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

function formatDate(dateStr: string): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return `${d.getDate()} ${monthNames[d.getMonth()]} ${d.getFullYear()}`;
}
---

<Layout title={`${PODCAST.title} | ${SITE.title}`} description={PODCAST.description}>
  <Header />
  <main id="main-content" class="relative z-1">
    <div class="mx-auto max-w-[740px] px-6">

      <!-- HERO -->
      <section class="pt-22 pb-10 relative" style="border: none;">
        <div class="absolute left-0 top-20 bottom-4 w-[3px] rounded-sm opacity-60" style="background: linear-gradient(180deg, var(--accent) 0%, var(--gold) 100%);"></div>

        <div class="font-[var(--font-mono)] text-xs font-medium text-accent tracking-[0.12em] uppercase mb-5 flex items-center gap-2.5">
          Podcast
          <span class="block w-8 h-px bg-accent-dim"></span>
        </div>
        <h1 class="font-[var(--font-head)] text-[clamp(32px,5vw,44px)] font-bold leading-[1.1] tracking-[-0.02em] text-foreground mb-4">
          {PODCAST.title}
        </h1>
        <p class="text-[17px] leading-[1.75] text-text-secondary max-w-[580px] mb-6">
          {PODCAST.description}
        </p>

        <!-- Platform links -->
        <div class="flex flex-wrap gap-3 items-center">
          <a href={PODCAST.spotifyUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#1DB954] text-[#000] font-[var(--font-body)] font-semibold text-sm px-5 py-2.5 rounded transition-all hover:brightness-110 hover:-translate-y-px hover:no-underline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Spotify
          </a>
          <a href={PODCAST.youtubeChannelUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#FF0000] text-white font-[var(--font-body)] font-semibold text-sm px-5 py-2.5 rounded transition-all hover:brightness-110 hover:-translate-y-px hover:no-underline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/></svg>
            YouTube
          </a>
        </div>
      </section>

      <div class="border-t border-border"></div>

      <!-- FEATURED EPISODE (THEATER MODE) -->
      {featuredEpisode && (
        <section class="py-12" style="border: none;">
          <div class="font-[var(--font-mono)] text-[11px] font-medium text-muted tracking-[0.14em] uppercase mb-6 flex items-center gap-2.5">
            Latest episode
            <span class="flex-1 h-px bg-border"></span>
          </div>

          <!-- Theater-mode video container -->
          <div class="theater-container group relative rounded-lg overflow-hidden bg-black shadow-2xl shadow-black/50">
            <div class="aspect-video">
              <iframe
                id="featured-player"
                src={`https://www.youtube-nocookie.com/embed/${featuredEpisode.id}?rel=0&modestbranding=1&color=white`}
                title={featuredEpisode.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                class="absolute inset-0 w-full h-full"
                loading="lazy"
              ></iframe>
            </div>
          </div>

          <div class="mt-5">
            <h2 class="font-[var(--font-head)] text-xl font-semibold text-foreground mb-1">{featuredEpisode.title}</h2>
            <span class="font-[var(--font-mono)] text-xs text-muted">{formatDate(featuredEpisode.published)}</span>
          </div>
        </section>
      )}

      <div class="border-t border-border"></div>

      <!-- SPOTIFY EMBED -->
      <section class="py-12" style="border: none;">
        <div class="font-[var(--font-mono)] text-[11px] font-medium text-muted tracking-[0.14em] uppercase mb-6 flex items-center gap-2.5">
          Listen on Spotify
          <span class="flex-1 h-px bg-border"></span>
        </div>
        <div class="rounded-lg overflow-hidden">
          <iframe
            src={`https://open.spotify.com/embed/show/${PODCAST.spotifyShowId}?utm_source=generator&theme=0`}
            width="100%"
            height="352"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            class="rounded-lg border border-border"
            style="border-radius: 12px;"
          ></iframe>
        </div>
      </section>

      {remainingEpisodes.length > 0 && (
        <>
          <div class="border-t border-border"></div>

          <!-- EPISODE GRID -->
          <section class="py-12" style="border: none;">
            <div class="font-[var(--font-mono)] text-[11px] font-medium text-muted tracking-[0.14em] uppercase mb-8 flex items-center gap-2.5">
              All episodes
              <span class="flex-1 h-px bg-border"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {remainingEpisodes.map((ep) => (
                <div
                  class="episode-card group cursor-pointer"
                  data-video-id={ep.id}
                  data-video-title={ep.title}
                >
                  <!-- Thumbnail -->
                  <div class="relative rounded-md overflow-hidden bg-background-raised border border-border aspect-video mb-3 transition-all duration-200 group-hover:border-accent-dim group-hover:shadow-lg group-hover:shadow-black/20">
                    <img
                      src={ep.thumbnail}
                      alt={ep.title}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                    <!-- Play overlay -->
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-black/40">
                      <div class="w-14 h-14 rounded-full bg-accent/90 flex items-center justify-center shadow-lg backdrop-blur-sm">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#0e1a0e"><polygon points="8,5 20,12 8,19"/></svg>
                      </div>
                    </div>
                    <!-- Duration-style accent bar on hover -->
                    <div class="absolute bottom-0 left-0 right-0 h-[3px] opacity-0 group-hover:opacity-100 transition-opacity" style="background: linear-gradient(90deg, var(--accent), var(--gold));"></div>
                  </div>

                  <!-- Meta -->
                  <h3 class="font-[var(--font-head)] text-[15px] font-semibold text-foreground leading-snug mb-1 group-hover:text-accent transition-colors">{ep.title}</h3>
                  <span class="font-[var(--font-mono)] text-[11px] text-muted">{formatDate(ep.published)}</span>
                </div>
              ))}
            </div>
          </section>
        </>
      )}

      <div class="border-t border-border"></div>

      <!-- CTA -->
      <section class="py-12" style="border: none;">
        <div class="bg-background-raised border border-border border-l-3 border-l-gold rounded-r-md py-6 px-7">
          <p class="text-text-secondary text-[15px] leading-[1.7] mb-3">
            <strong class="text-foreground font-semibold">Want to be a guest?</strong>{' '}
            If you've got strong opinions of your own and you're not afraid to share them — I'd love to have the conversation.
          </p>
          <a href="/contact" class="inline-flex items-center gap-[7px] bg-accent text-[#0e1a0e] font-[var(--font-body)] font-semibold text-sm px-5 py-2.5 rounded transition-all hover:brightness-110 hover:-translate-y-px hover:no-underline mt-2">
            Get in touch
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* ── THEATER MODE ──────────────────────────────────────────── */
  .theater-container {
    transition: all 0.3s ease;
  }

  /* Cinematic glow effect on the featured video */
  .theater-container::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--accent), var(--gold), var(--accent));
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
  }
  .theater-container:hover::before {
    opacity: 0.4;
  }

  /* Episode card click-to-play animation */
  .episode-card {
    transition: transform 0.15s ease;
  }
  .episode-card:active {
    transform: scale(0.98);
  }

  /* Smooth iframe transitions */
  iframe {
    transition: opacity 0.3s ease;
  }

  /* Theater expand animation */
  @keyframes theaterIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .theater-expand {
    animation: theaterIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script>
  function setupPodcastPage() {
    const cards = document.querySelectorAll(".episode-card");
    const featuredPlayer = document.querySelector("#featured-player") as HTMLIFrameElement;
    const theaterContainer = document.querySelector(".theater-container");

    if (!featuredPlayer || !theaterContainer) return;

    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const videoId = card.getAttribute("data-video-id");
        const videoTitle = card.getAttribute("data-video-title");
        if (!videoId) return;

        // Update the featured player
        featuredPlayer.src = `https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1&color=white&autoplay=1`;
        featuredPlayer.title = videoTitle || "";

        // Update the title below the player
        const titleEl = theaterContainer.parentElement?.querySelector("h2");
        if (titleEl && videoTitle) titleEl.textContent = videoTitle;

        // Update the date
        const dateEl = theaterContainer.parentElement?.querySelector("span");
        if (dateEl) {
          // Find the matching card's date
          const cardDate = card.querySelector("span");
          if (cardDate) dateEl.textContent = cardDate.textContent || "";
        }

        // Animate
        theaterContainer.classList.remove("theater-expand");
        void (theaterContainer as HTMLElement).offsetWidth; // force reflow
        theaterContainer.classList.add("theater-expand");

        // Scroll to player
        theaterContainer.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    });
  }

  setupPodcastPage();
  document.addEventListener("astro:after-swap", setupPodcastPage);
</script>
