# ── Astro (required for server mode) ───────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
ASTRO_KEY=your-base64-key-here

# ── MS Graph API (Contact Form) ────────────────────────────────
# See docs/contact-form-ms-graph.md for setup instructions.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
MAIL_SENDER=hello@darrylmunro.me
MAIL_RECIPIENT=darryl@darrylmunro.nz
